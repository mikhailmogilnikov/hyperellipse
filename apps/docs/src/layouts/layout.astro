---
import { Font } from "astro:assets";
import "../styles/global.css";

interface Props {
  class?: string;
  title?: string;
}

const { title = "Hyperellipse", class: className } = Astro.props;
---

<!doctype html>
<html lang="en" style="color-scheme: light dark">
  <head>
    <meta charset="UTF-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="light dark" name="color-scheme">
    <meta
      content="#f2f2f2"
      media="(prefers-color-scheme: light)"
      name="theme-color"
    >
    <meta
      content="#000000"
      media="(prefers-color-scheme: dark)"
      name="theme-color"
    >
    <link
      rel="icon"
      type="image/png"
      href="/favicon-96x96.png?v=20260612"
      sizes="96x96"
    >
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260612">
    <link rel="shortcut icon" href="/favicon.ico?v=20260612">
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-touch-icon.png?v=20260612"
    >
    <meta name="apple-mobile-web-app-title" content="hyperellipse">
    <link rel="manifest" href="/site.webmanifest?v=20260612">
    <Font cssVariable="--font-geist" preload />
    <Font cssVariable="--font-geist-mono" preload />
    <title>{title}</title>
    <meta
      name="description"
      content="CSS polyfill for squircles, superellipses, scoops, notches in any browser. Supports every frontend framework. SSR-friendly. Open-source."
    >
    <meta
      name="keywords"
      content="CSS, polyfill, squircles, superellipses, scoops, notches, browser, frontend, framework, SSR, open-source"
    >
    <meta name="author" content="Mikhail Mogilnikov">
    <meta name="robots" content="index, follow">
    <meta name="googlebot" content="index, follow">
  </head>
  <body
    class:list={[
      "min-h-dvh bg-background text-foreground font-sans antialiased",
      className,
    ]}
  >
    <slot />
    <script>
      import { registerHyperellipse } from "hyperellipse";

      registerHyperellipse();
    </script>
  </body>
</html>

---
import {
  frameworkTabs,
  ssrFallbackCode,
  stylingCode,
} from "../lib/quick-start-frameworks";
import CodeBlock from "./code-block.astro";
import CodeTabs from "./code-tabs.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<section
  class:list={["flex w-full scroll-mt-8 flex-col gap-5", className]}
  id="quick-start"
>
  <span class="docs-section-label">Quick start</span>

  <ol class="m-0 flex list-none flex-col gap-5 p-0">
    <li class="flex flex-col gap-2.5">
      <div class="flex flex-col gap-1">
        <span class="docs-heading">
          <span class="text-foreground/40">1.</span>
          Register on the client
        </span>
        <p class="docs-text m-0">
          Call
          <code class="font-mono text-foreground/70"
            >registerHyperellipse()</code
          >
          once on the client — in
          <code class="font-mono text-foreground/70">App</code>, root layout, or
          entry file. Safe to call again; no-op during SSR.
        </p>
      </div>

      <CodeTabs
        ariaLabel="Frontend framework"
        copyLabel="Copy registration code"
        panelId="quick-start-register-panel"
        tabs={frameworkTabs}
      />
    </li>

    <li class="flex flex-col gap-2.5">
      <div class="flex flex-col gap-1">
        <span class="docs-heading">
          <span class="text-foreground/40">2.</span>
          Style elements
        </span>
        <p class="docs-text m-0">
          Set
          <code class="font-mono text-foreground/70">--corner-shape</code>
          next to
          <code class="font-mono text-foreground/70">border-radius</code>
          — the custom property survives in the CSSOM where native
          <code class="font-mono text-foreground/70">corner-shape</code>
          is dropped.
        </p>
        <p class="docs-text-muted m-0">
          Tip: add
          <code class="font-mono text-foreground/55"
            >corner-shape: squircle</code
          >
          for native zero-JS rendering.
        </p>
      </div>

      <CodeBlock code={stylingCode} copyLabel="Copy styling code" lang="css" />
    </li>

    <li class="flex flex-col gap-2.5">
      <div class="flex flex-col gap-1">
        <span class="docs-heading">
          <span class="text-foreground/40">3.</span>
          SSR fallback
          <span class="font-normal text-foreground/40">(recommended)</span>
        </span>
        <p class="docs-text m-0">
          Squircles look less round than circles at the same radius. Add this
          global snippet so unsupported browsers set
          <code class="font-mono text-foreground/70">--corner-scale: 0.6</code>
          before JS loads.
        </p>
      </div>

      <CodeBlock
        code={ssrFallbackCode}
        copyLabel="Copy SSR fallback code"
        lang="css"
      />
    </li>
  </ol>
</section>

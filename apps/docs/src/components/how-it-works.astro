---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const rows = [
  {
    description:
      "Injects corner-shape: var(--corner-shape, round) via an @property bridge. Native rendering, no JS observers.",
    title: "Chrome / native corner-shape",
  },
  {
    description:
      "Scans stylesheets for --corner-shape and renders matching elements with clip-path and SVG layers.",
    title: "Safari / Firefox",
  },
  {
    description:
      "The hyperellipse/css snippet sets --corner-scale so corners look right before JS loads.",
    title: "SSR",
  },
] as const;
---

<section class:list={["flex w-full flex-col gap-3", className]}>
  <span class="text-xs font-semibold tracking-wide text-foreground uppercase"
    >How it works</span
  >

  <div
    class="squircle flex flex-col overflow-hidden rounded-2xl border border-foreground/8 bg-foreground/4"
  >
    {rows.map((row, index) => (
        <div
          class:list={[
            "flex flex-col gap-1 px-4 py-3",
            index > 0 ? "border-foreground/8 border-t" : "",
          ]}
        >
          <span class="font-semibold text-[0.8125rem] text-foreground tracking-tight">
            {row.title}
          </span>
          <p class="m-0 text-[0.8125rem] text-foreground/50 leading-relaxed">
            {row.description}
          </p>
        </div>
      ))}
  </div>
</section>

---
import DemoSelect from "./demo-select.astro";
import ScrubInput from "./scrub-input.astro";

const defaultRadius = 60;
const defaultCurve = 2;
const defaultCornerShapeKind = "superellipse";
const defaultBorder = 0;
const defaultShadow = 0;
const defaultOutline = 0;
const defaultOutlineOffset = 0;

const cornerShapeOptions = [
  { value: "superellipse", label: "superellipse" },
  { value: "bevel", label: "bevel" },
  { value: "scoop", label: "scoop" },
  { value: "notch", label: "notch" },
  { value: "mixed", label: "Per-corner mix" },
] as const;
---

<div
  class="flex w-full gap-4 max-[576px]:flex-col-reverse"
  data-squircle-panels
>
  <div
    class="flex max-[576px]:min-h-34 max-[576px]:w-full w-54 shrink-0 flex-col gap-3 squircle rounded-3xl bg-card p-4"
  >
    <span class="text-xs font-semibold tracking-wide text-foreground uppercase"
      >CSS</span
    >
    <pre
      class="scrollbar-styled m-0 min-h-0 flex-1 overflow-auto p-0 font-mono text-xs leading-normal whitespace-pre text-foreground/80"
    ><code data-squircle-css></code></pre>
  </div>

  <div
    class="flex min-h-48 min-w-0 grow flex-col gap-3 squircle rounded-3xl bg-card p-4"
  >
    <span class="text-xs font-semibold tracking-wide text-foreground uppercase"
      >Settings</span
    >
    <div class="flex flex-col gap-3">
      <div
        class="flex flex-col gap-3 transition-opacity duration-150 data-disabled:pointer-events-none data-disabled:opacity-40"
        data-corner-shape-controls
      >
        <DemoSelect
          label="Shape"
          name="corner-shape-kind"
          options={[...cornerShapeOptions]}
          value={defaultCornerShapeKind}
        />
        <div
          class="transition-opacity duration-150 data-disabled:pointer-events-none data-disabled:opacity-40"
          data-curve-control
        >
          <ScrubInput
            class="**:data-scrub-value:w-10"
            label="Curve"
            max={10}
            min={1}
            name="curve"
            step={0.1}
            unit=""
            value={defaultCurve}
          />
        </div>
      </div>
      <ScrubInput
        label="Border radius"
        max={128}
        min={0}
        name="radius"
        step={1}
        unit="px"
        value={defaultRadius}
      />
      <ScrubInput
        label="Border"
        max={16}
        min={0}
        name="border"
        step={1}
        unit="px"
        value={defaultBorder}
      />
      <ScrubInput
        label="Shadow"
        max={32}
        min={0}
        name="shadow"
        step={1}
        unit="px"
        value={defaultShadow}
      />
      <ScrubInput
        label="Outline"
        max={16}
        min={0}
        name="outline"
        step={1}
        unit="px"
        value={defaultOutline}
      />
      <ScrubInput
        label="Outline offset"
        max={32}
        min={0}
        name="outline-offset"
        step={1}
        unit="px"
        value={defaultOutlineOffset}
      />
    </div>
  </div>
</div>

<script>
  type CornerShapeKind = "superellipse" | "bevel" | "scoop" | "notch" | "mixed";

  const MIXED_CORNER_SHAPE = "squircle bevel scoop notch";

  interface DemoPanelState {
    border: number;
    cornerShapeKind: CornerShapeKind;
    curve: number;
    hyperellipse: boolean;
    outline: number;
    outlineOffset: number;
    radius: number;
    shadow: number;
  }

  const TRAILING_ZERO_RE = /\.0$/;
  const SUPERELLIPSE_RE = /superellipse\(\s*([-\d.]+)/i;

  const formatCurve = (curve: number) =>
    Number.isInteger(curve)
      ? String(curve)
      : curve.toFixed(1).replace(TRAILING_ZERO_RE, "");

  const formatCornerShape = ({
    cornerShapeKind,
    curve,
  }: Pick<DemoPanelState, "cornerShapeKind" | "curve">) => {
    if (cornerShapeKind === "bevel") {
      return "bevel";
    }

    if (cornerShapeKind === "scoop") {
      return "scoop";
    }

    if (cornerShapeKind === "notch") {
      return "notch";
    }

    if (cornerShapeKind === "mixed") {
      return MIXED_CORNER_SHAPE;
    }

    if (curve === 1) {
      return "round";
    }

    if (curve === 2) {
      return "squircle";
    }

    return `superellipse(${formatCurve(curve)})`;
  };

  const formatShadow = (shadow: number) =>
    `0 ${shadow}px ${shadow * 2}px rgb(0 0 0 / 0.25)`;

  const formatCss = ({
    border,
    cornerShapeKind,
    curve,
    hyperellipse,
    outline,
    outlineOffset,
    radius,
    shadow,
  }: DemoPanelState) => {
    const lines = [".card {"];

    if (hyperellipse) {
      lines.push(
        `  --corner-shape: ${formatCornerShape({ cornerShapeKind, curve })};`
      );
    }

    lines.push(`  border-radius: ${radius}px;`);

    if (border > 0) {
      lines.push(`  border: ${border}px solid;`);
    }

    if (shadow > 0) {
      lines.push(`  box-shadow: ${formatShadow(shadow)};`);
    }

    if (outline > 0) {
      lines.push(`  outline: ${outline}px solid;`);
    }

    if (outline > 0 && outlineOffset > 0) {
      lines.push(`  outline-offset: ${outlineOffset}px;`);
    }

    lines.push("}");
    return lines.join("\n");
  };

  const parseCssVar = (block: HTMLElement, name: string, fallback: number) => {
    const custom = block.style.getPropertyValue(name).trim();

    if (!custom) {
      return fallback;
    }

    const parsed = Number.parseFloat(custom);
    return Number.isFinite(parsed) ? parsed : fallback;
  };

  const initSquircleDemoPanels = (root: HTMLElement) => {
    const demo = root.closest("[data-squircle-demo]");

    if (!demo) {
      return;
    }

    const block = demo.querySelector<HTMLElement>("[data-demo-block]");
    const cssOutput = root.querySelector("[data-squircle-css]");
    const radiusControl = root.querySelector<HTMLElement>(
      '[data-scrub-input][data-name="radius"]'
    );
    const borderControl = root.querySelector<HTMLElement>(
      '[data-scrub-input][data-name="border"]'
    );
    const shadowControl = root.querySelector<HTMLElement>(
      '[data-scrub-input][data-name="shadow"]'
    );
    const outlineControl = root.querySelector<HTMLElement>(
      '[data-scrub-input][data-name="outline"]'
    );
    const outlineOffsetControl = root.querySelector<HTMLElement>(
      '[data-scrub-input][data-name="outline-offset"]'
    );
    const hyperellipseToggle = demo.querySelector<HTMLInputElement>(
      '[data-toggle-input][name="hyperellipse"]'
    );
    const cornerShapeKindControl = root.querySelector<HTMLElement>(
      '[data-demo-select][data-name="corner-shape-kind"]'
    );
    const cornerShapeKindSelect =
      cornerShapeKindControl?.querySelector<HTMLSelectElement>(
        "[data-demo-select-value]"
      );
    const curveControl = root.querySelector<HTMLElement>(
      '[data-scrub-input][data-name="curve"]'
    );
    const curveWrapper = root.querySelector<HTMLElement>(
      "[data-curve-control]"
    );
    const cornerShapeControls = root.querySelector<HTMLElement>(
      "[data-corner-shape-controls]"
    );

    if (
      !(
        block &&
        cssOutput &&
        radiusControl &&
        borderControl &&
        shadowControl &&
        outlineControl &&
        outlineOffsetControl &&
        hyperellipseToggle &&
        cornerShapeKindControl &&
        cornerShapeKindSelect &&
        curveControl &&
        curveWrapper &&
        cornerShapeControls
      )
    ) {
      return;
    }

    const parseCurve = (value: string) => {
      if (value === "round") {
        return 1;
      }

      if (value === "squircle") {
        return 2;
      }

      const match = value.match(SUPERELLIPSE_RE);
      if (!match?.[1]) {
        return 2;
      }

      const parsed = Number.parseFloat(match[1]);
      return Number.isFinite(parsed) ? parsed : 2;
    };

    const parseCornerShapeKind = (
      value: string
    ): Pick<DemoPanelState, "cornerShapeKind" | "curve"> => {
      if (value === "bevel") {
        return { cornerShapeKind: "bevel", curve: 2 };
      }

      if (value === "scoop") {
        return { cornerShapeKind: "scoop", curve: 2 };
      }

      if (value === "notch") {
        return { cornerShapeKind: "notch", curve: 2 };
      }

      if (value.replace(/\s+/g, " ").trim() === MIXED_CORNER_SHAPE) {
        return { cornerShapeKind: "mixed", curve: 2 };
      }

      return {
        cornerShapeKind: "superellipse",
        curve: parseCurve(value),
      };
    };

    const cornerShape =
      block.style.getPropertyValue("--corner-shape").trim() ||
      block.style.getPropertyValue("corner-shape").trim();
    const parsedCornerShape = parseCornerShapeKind(
      cornerShape.length > 0 ? cornerShape : "squircle"
    );

    const state: DemoPanelState = {
      radius: parseCssVar(block, "--radius", 60),
      border: parseCssVar(block, "--border-width", 0),
      shadow: parseCssVar(block, "--shadow-size", 0),
      outline: parseCssVar(block, "--outline-width", 0),
      outlineOffset: parseCssVar(block, "--outline-offset", 0),
      hyperellipse: cornerShape.length > 0,
      cornerShapeKind: parsedCornerShape.cornerShapeKind,
      curve: parsedCornerShape.curve,
    };

    hyperellipseToggle.checked = state.hyperellipse;
    cornerShapeKindSelect.value = state.cornerShapeKind;
    cornerShapeControls.toggleAttribute("data-disabled", !state.hyperellipse);
    curveWrapper.toggleAttribute(
      "data-disabled",
      !state.hyperellipse || state.cornerShapeKind !== "superellipse"
    );

    const syncControl = (control: HTMLElement, value: number) => {
      control.dataset.value = String(value);
      const input =
        control.querySelector<HTMLInputElement>("[data-scrub-value]");

      if (input) {
        input.value = String(value);
      }
    };

    const render = () => {
      cssOutput.textContent = formatCss(state);
    };

    const apply = () => {
      cornerShapeControls.toggleAttribute("data-disabled", !state.hyperellipse);
      curveWrapper.toggleAttribute(
        "data-disabled",
        !state.hyperellipse || state.cornerShapeKind !== "superellipse"
      );

      if (state.hyperellipse) {
        const cornerShapeValue = formatCornerShape({
          cornerShapeKind: state.cornerShapeKind,
          curve: state.curve,
        });

        block.style.setProperty("--corner-shape", cornerShapeValue);
        block.style.setProperty("corner-shape", cornerShapeValue);
      } else {
        block.style.removeProperty("--corner-shape");
        block.style.removeProperty("corner-shape");
      }

      block.style.setProperty("--radius", `${state.radius}px`);
      block.style.setProperty("--border-width", `${state.border}px`);
      block.style.setProperty("--shadow-size", `${state.shadow}px`);
      block.style.setProperty("--outline-width", `${state.outline}px`);
      block.style.setProperty("--outline-offset", `${state.outlineOffset}px`);
      render();
    };

    syncControl(radiusControl, state.radius);
    syncControl(curveControl, state.curve);
    syncControl(borderControl, state.border);
    syncControl(shadowControl, state.shadow);
    syncControl(outlineControl, state.outline);
    syncControl(outlineOffsetControl, state.outlineOffset);
    apply();

    curveControl.addEventListener("scrub-input:change", (event) => {
      state.curve = (event as CustomEvent<{ value: number }>).detail.value;
      apply();
    });

    cornerShapeKindControl.addEventListener("demo-select:change", (event) => {
      state.cornerShapeKind = (
        event as CustomEvent<{ value: CornerShapeKind }>
      ).detail.value;
      apply();
    });

    radiusControl.addEventListener("scrub-input:change", (event) => {
      state.radius = (event as CustomEvent<{ value: number }>).detail.value;
      apply();
    });

    borderControl.addEventListener("scrub-input:change", (event) => {
      state.border = (event as CustomEvent<{ value: number }>).detail.value;
      apply();
    });

    shadowControl.addEventListener("scrub-input:change", (event) => {
      state.shadow = (event as CustomEvent<{ value: number }>).detail.value;
      apply();
    });

    outlineControl.addEventListener("scrub-input:change", (event) => {
      state.outline = (event as CustomEvent<{ value: number }>).detail.value;
      apply();
    });

    outlineOffsetControl.addEventListener("scrub-input:change", (event) => {
      state.outlineOffset = (
        event as CustomEvent<{ value: number }>
      ).detail.value;
      apply();
    });

    hyperellipseToggle.addEventListener("change", () => {
      state.hyperellipse = hyperellipseToggle.checked;
      apply();
    });
  };

  for (const panels of document.querySelectorAll<HTMLElement>(
    "[data-squircle-panels]"
  )) {
    initSquircleDemoPanels(panels);
  }
</script>

---
import { ChevronRight } from "@lucide/astro";
import { detailExampleGroups } from "../lib/detail-examples";
import DetailExampleCard from "./detail-example-card.astro";
import RealWorldUiExampleGrid from "./real-world-ui-example-grid.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<section
  class:list={["flex w-full flex-col gap-3", className]}
  data-detail-examples
>
  <h2 class="docs-section-label">Examples</h2>

  <div
    class="squircle flex flex-col overflow-hidden rounded-2xl border border-foreground/8 bg-card"
  >
    {detailExampleGroups.map((group) => (
        <details class="group/details border-foreground/8 border-t first:border-t-0">
          <summary
            class="detail-example-summary flex cursor-pointer list-none items-center gap-1.5 px-4 py-3 transition-colors hover:bg-foreground/3"
          >
            <ChevronRight
              aria-hidden="true"
              class="size-3.5 shrink-0 text-foreground/40 transition-transform duration-150 group-open/details:rotate-90"
            />
            <h3 class="docs-heading">{group.title}</h3>
          </summary>

          <div
            class:list={[
              "px-4 pt-4 pb-4",
              group.subgroups ? "flex flex-col gap-5" : null,
            ]}
          >
            {group.note ? (
              <p class="m-0 text-foreground/50 text-sm leading-relaxed">
                {group.note}
              </p>
            ) : null}

            {group.subgroups?.map((subgroup) => (
              <div class="flex flex-col gap-3">
                <div class="flex flex-col gap-1.5">
                  <h4 class="docs-heading">{subgroup.title}</h4>
                  {subgroup.note ? (
                    <p class="m-0 text-foreground/50 text-sm leading-relaxed">
                      {subgroup.note}
                    </p>
                  ) : null}
                </div>
                <div class="grid grid-cols-1 gap-3 min-[576px]:grid-cols-2">
                  {subgroup.examples.map((example) => (
                    <DetailExampleCard
                      caption={example.caption}
                      css={example.css}
                      figureClass={example.figureClass}
                      previewClass={example.previewClass}
                    />
                  ))}
                </div>
              </div>
            ))}

            {group.examples ? (
              <div class="grid grid-cols-1 gap-3 min-[576px]:grid-cols-2">
                {group.examples.map((example) => (
                  <DetailExampleCard
                    caption={example.caption}
                    css={example.css}
                    figureClass={example.figureClass}
                    previewClass={example.previewClass}
                  />
                ))}
              </div>
            ) : null}
          </div>
        </details>
      ))}

    <details class="group/details border-foreground/8 border-t">
      <summary
        class="detail-example-summary flex cursor-pointer list-none items-center gap-1.5 px-4 py-3 transition-colors hover:bg-foreground/3"
      >
        <ChevronRight
          aria-hidden="true"
          class="size-3.5 shrink-0 text-foreground/40 transition-transform duration-150 group-open/details:rotate-90"
        />
        <h3 class="docs-heading">Real-world UI</h3>
      </summary>

      <RealWorldUiExampleGrid />
    </details>
  </div>
</section>

<script>
  import { registerHyperellipse } from "hyperellipse";

  const refreshExamples = () => {
    registerHyperellipse().refresh();
  };

  const initDetailExamples = () => {
    const root = document.querySelector("[data-detail-examples]");
    if (!root) {
      return;
    }

    for (const details of root.querySelectorAll("details")) {
      details.addEventListener("toggle", refreshExamples);
    }
  };

  initDetailExamples();
  document.addEventListener("astro:page-load", initDetailExamples);
</script>

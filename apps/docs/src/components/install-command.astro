---
import { Check, Copy } from "@lucide/astro";
import { highlightCode } from "../lib/highlight";

interface Props {
  class?: string;
  packageName?: string;
}

const { class: className, packageName = "hyperellipse" } = Astro.props;

const packageManagers = [
  { id: "npm", label: "npm", command: `npm install ${packageName}` },
  { id: "pnpm", label: "pnpm", command: `pnpm add ${packageName}` },
  { id: "yarn", label: "yarn", command: `yarn add ${packageName}` },
  { id: "bun", label: "bun", command: `bun add ${packageName}` },
] as const;

const highlightedManagers = await Promise.all(
  packageManagers.map(async (manager) => ({
    ...manager,
    highlighted: await highlightCode(manager.command, "shell"),
  }))
);

const defaultManager = highlightedManagers[0];
---

<section
  class:list={["flex w-full flex-col gap-3", className]}
  data-install-command
>
  <div class="flex items-center justify-between gap-3">
    <span class="docs-section-label">Install</span>
    <div
      class="squircle flex items-center gap-0.5 rounded-lg border border-foreground/8 bg-card p-0.5"
      role="tablist"
      aria-label="Package manager"
    >
      {highlightedManagers.map((manager, index) => (
          <button
            aria-controls="install-command-panel"
            aria-selected={index === 0}
            class="docs-tab data-active:shadow-[0_1px_2px_rgb(0_0_0/0.06)]"
            data-active={index === 0 ? "" : undefined}
            data-install-tab={manager.id}
            role="tab"
            type="button"
          >
            {manager.label}
          </button>
        ))}
    </div>
  </div>

  <div
    class="code-block-panel install-command-panel squircle"
    data-code-block
    data-code-source={defaultManager.command}
    id="install-command-panel"
    role="tabpanel"
  >
    <div class="install-command-scroll">
      <div
        class="code-block m-0 min-w-0"
        data-install-highlight
        set:html={defaultManager.highlighted}
      />
    </div>
    <button
      aria-label="Copy install command"
      class="install-command-copy"
      data-code-copy
      type="button"
    >
      <Copy aria-hidden="true" class="size-3.5" data-code-copy-icon />
      <Check
        aria-hidden="true"
        class="hidden size-3.5 text-[#34c759]"
        data-code-check-icon
      />
    </button>
  </div>

  <div aria-hidden="true" class="hidden">
    {highlightedManagers.map((manager) => (
        <>
          <template data-install-template={manager.id}>
            {manager.command}
          </template>
          <div
            data-install-highlight-template={manager.id}
            set:html={manager.highlighted}
          />
        </>
      ))}
  </div>
</section>

<script>
  const COPY_FEEDBACK_MS = 2000;

  const collectInstallTemplates = (root: HTMLElement) => {
    const commands = new Map<string, string>();
    const highlights = new Map<string, string>();

    for (const template of root.querySelectorAll("[data-install-template]")) {
      if (!(template instanceof HTMLTemplateElement)) {
        continue;
      }

      const manager = template.dataset.installTemplate;
      if (!manager) {
        continue;
      }

      commands.set(manager, template.content.textContent?.trim() ?? "");
    }

    for (const node of root.querySelectorAll(
      "[data-install-highlight-template]"
    )) {
      if (!(node instanceof HTMLElement)) {
        continue;
      }

      const manager = node.dataset.installHighlightTemplate;
      if (!manager) {
        continue;
      }

      highlights.set(manager, node.innerHTML);
    }

    return { commands, highlights };
  };

  const setupInstallTabs = (
    tabs: NodeListOf<Element>,
    templates: ReturnType<typeof collectInstallTemplates>,
    panel: HTMLElement,
    highlight: HTMLElement
  ) => {
    const setActiveTab = (managerId: string) => {
      const command = templates.commands.get(managerId);
      const highlighted = templates.highlights.get(managerId);

      if (!(command && highlighted)) {
        return;
      }

      panel.dataset.codeSource = command;
      highlight.innerHTML = highlighted;

      for (const tab of tabs) {
        if (!(tab instanceof HTMLButtonElement)) {
          continue;
        }

        const isActive = tab.dataset.installTab === managerId;
        tab.setAttribute("aria-selected", String(isActive));
        tab.toggleAttribute("data-active", isActive);
      }
    };

    for (const tab of tabs) {
      if (!(tab instanceof HTMLButtonElement)) {
        continue;
      }

      tab.addEventListener("click", () => {
        const managerId = tab.dataset.installTab;
        if (managerId) {
          setActiveTab(managerId);
        }
      });
    }
  };

  const setupCodeBlockCopy = (root: HTMLElement) => {
    const copyButton = root.querySelector("[data-code-copy]");

    if (!(copyButton instanceof HTMLButtonElement)) {
      return;
    }

    const copyIcon = copyButton.querySelector("[data-code-copy-icon]");
    const checkIcon = copyButton.querySelector("[data-code-check-icon]");
    let copyTimeout: ReturnType<typeof setTimeout> | undefined;

    const setCopied = (copied: boolean) => {
      copyIcon?.classList.toggle("hidden", copied);
      checkIcon?.classList.toggle("hidden", !copied);
    };

    copyButton.addEventListener("click", async () => {
      const source = root.dataset.codeSource?.trim();
      if (!source) {
        return;
      }

      try {
        await navigator.clipboard.writeText(source);
      } catch {
        return;
      }

      setCopied(true);

      if (copyTimeout) {
        clearTimeout(copyTimeout);
      }

      copyTimeout = setTimeout(() => {
        setCopied(false);
      }, COPY_FEEDBACK_MS);
    });
  };

  const initInstallCommand = (root: HTMLElement) => {
    if (root.dataset.installReady === "true") {
      return;
    }

    root.dataset.installReady = "true";

    const panel = root.querySelector("[data-code-block]");
    const highlight = root.querySelector("[data-install-highlight]");
    const tabs = root.querySelectorAll("[data-install-tab]");

    if (!(panel instanceof HTMLElement && highlight instanceof HTMLElement)) {
      return;
    }

    setupInstallTabs(tabs, collectInstallTemplates(root), panel, highlight);
    setupCodeBlockCopy(panel);
  };

  const initInstallCommands = () => {
    for (const root of document.querySelectorAll("[data-install-command]")) {
      if (root instanceof HTMLElement) {
        initInstallCommand(root);
      }
    }
  };

  initInstallCommands();
  document.addEventListener("astro:page-load", initInstallCommands);
</script>

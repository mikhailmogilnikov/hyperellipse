---
import { ChevronRight } from "@lucide/astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const browsers = [
  { name: "Chrome", mode: "native" as const },
  { name: "Edge", mode: "native" as const },
  { name: "Safari", mode: "polyfill" as const },
  { name: "Firefox", mode: "polyfill" as const },
] as const;
---

<details class:list={["group/support border-foreground/8 border-t", className]}>
  <summary
    class="detail-example-summary flex cursor-pointer list-none items-center gap-1.5 px-4 py-3 transition-colors hover:bg-foreground/3"
  >
    <ChevronRight
      aria-hidden="true"
      class="size-3.5 shrink-0 text-foreground/40 transition-transform duration-150 group-open/support:rotate-90"
    />
    <h3 class="docs-heading">Browser support</h3>
  </summary>

  {browsers.map((browser) => (
    <div class="flex items-baseline justify-between gap-4 border-foreground/8 border-t px-4 py-3">
      <h4 class="docs-heading">{browser.name}</h4>
      {
        browser.mode === "native" ? (
          <span class="font-medium text-foreground/45 text-sm tracking-tight">
            Native
          </span>
        ) : (
          <span class="font-semibold text-foreground text-sm tracking-tight">
            hyperellipse
          </span>
        )
      }
    </div>
  ))}
</details>

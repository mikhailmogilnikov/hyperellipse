---
import { ChevronRight } from "@lucide/astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const rows = [
  {
    description:
      "Native corner-shape via an @property bridge. No JS observers, no layout work — set --corner-shape and border-radius in CSS.",
    title: "Chrome",
  },
  {
    description:
      "JS fallback scans stylesheets for --corner-shape and renders with clip-path and SVG layers. Call registerHyperellipse() once on the client.",
    title: "Safari / Firefox",
  },
  {
    description:
      "Import hyperellipse/css or add the @supports not snippet so --corner-scale softens corners before hydration.",
    title: "SSR",
  },
] as const;
---

<details class:list={["group/support border-foreground/8 border-t", className]}>
  <summary
    class="detail-example-summary flex cursor-pointer list-none items-center gap-1.5 px-4 py-3 transition-colors hover:bg-foreground/3"
  >
    <ChevronRight
      aria-hidden="true"
      class="size-3.5 shrink-0 text-foreground/40 transition-transform duration-150 group-open/support:rotate-90"
    />
    <h3 class="docs-heading">Browser support</h3>
  </summary>

  {rows.map((row) => (
      <div class="flex flex-col gap-1 border-foreground/8 border-t px-4 py-3">
        <h4 class="docs-heading">
          {row.title}
        </h4>
        <p class="docs-text m-0">
          {row.description}
        </p>
      </div>
    ))}
</details>

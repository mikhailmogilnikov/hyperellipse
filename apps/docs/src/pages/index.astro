---
import { Star } from "@lucide/astro";
import AgentSkill from "../components/agent-skill.astro";
import Api from "../components/api.astro";
import BrowserSupport from "../components/browser-support.astro";
import DetailExamples from "../components/detail-examples.astro";
import HowItWorks from "../components/how-it-works.astro";
import HyperellipseLogo from "../components/hyperellipse-logo.astro";
import InstallCommand from "../components/install-command.astro";
import InstallCta from "../components/install-cta.astro";
import KnownLimitations from "../components/known-limitations.astro";
import QuickStart from "../components/quick-start.astro";
import SquircleDemo from "../components/squircle-demo.astro";
import SquircleDemoPanels from "../components/squircle-demo-panels.astro";
import ToggleSwitch from "../components/toggle-switch.astro";
import WhyHyperellipse from "../components/why-hyperellipse.astro";
import Layout from "../layouts/layout.astro";

const title = "hyperellipse";
---

<Layout title={title}>
  <main
    id="main-content"
    class="flex min-h-dvh items-center flex-col max-w-xl px-4 mx-auto pt-12 gap-8 tracking-tight"
  >
    <header class="flex flex-col gap-6 items-center">
      <HyperellipseLogo />
      <h1
        class="text-[2.5rem] font-bold text-gradient bg-linear-30 from-foreground to-foreground/60"
      >
        {title}
      </h1>
      <div class="flex max-w-lg flex-col gap-1 text-center">
        <h2 class="text-lg font-medium text-balance">
          <span class="text-foreground/50">CSS</span>
          <code class="rounded-md bg-card px-1 py-0.5 font-mono squircle"
            >corner-shape</code
          >
          <span class="text-foreground/50"
            >polyfill. Consistent rendering across browsers.</span
          >
        </h2>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-2">
        <a
          class="squircle inline-flex h-10 items-center justify-center rounded-xl bg-card shadow-md px-4 font-semibold text-[0.8125rem] text-foreground tracking-tight"
          href="#quick-start"
        >
          Quick start
        </a>
        <a
          class="squircle inline-flex h-10 items-center justify-center gap-1.5 rounded-xl bg-card shadow-md px-4 font-semibold text-[0.8125rem] text-foreground tracking-tight"
          href="https://github.com/mikhailmogilnikov/hyperellipse"
          rel="noopener noreferrer"
          target="_blank"
        >
          <Star aria-hidden="true" class="size-3.5" />
          Star on GitHub
        </a>
        <InstallCta />
      </div>
      <div class="-mb-2 flex flex-col gap-1 text-center">
        <p class="text-sm font-medium text-balance text-foreground/40">
          Native in Chromium · Spec-accurate fallback for Safari and Firefox
        </p>
        <p class="text-sm font-medium text-foreground/40">
          9.3 kB gzip · Framework-agnostic · SSR-friendly
        </p>
      </div>
    </header>
    <section class="flex w-full flex-col gap-4" data-squircle-demo>
      <div
        class="card squircle relative flex h-80 w-full items-center justify-center rounded-3xl bg-card"
      >
        <div class="absolute top-4 right-4 z-10">
          <ToggleSwitch checked label="Corner shape" name="hyperellipse" />
        </div>
        <SquircleDemo />
      </div>
      <SquircleDemoPanels />
    </section>
    <section class="flex w-full flex-col gap-3">
      <h2 class="docs-section-label">Overview</h2>
      <div
        class="squircle flex flex-col overflow-hidden rounded-2xl border border-foreground/8 bg-card"
      >
        <WhyHyperellipse class="border-t-0" />
        <BrowserSupport class="border-foreground/8 border-t" />
      </div>
    </section>
    <InstallCommand />
    <AgentSkill />
    <QuickStart />
    <section class="flex w-full flex-col gap-3">
      <h2 class="docs-section-label">Reference</h2>
      <div
        class="squircle flex flex-col overflow-hidden rounded-2xl border border-foreground/8 bg-card"
      >
        <Api />
        <HowItWorks />
        <KnownLimitations />
      </div>
    </section>
    <DetailExamples />

    <footer
      class="flex h-40 flex-col items-center justify-center gap-1 text-center text-sm font-medium text-foreground/40"
    >
      <HyperellipseLogo class="h-8 text-foreground/35 mb-6" />
      <p class="m-0">
        Designed and developed by
        <a
          class="text-foreground/55 transition-colors hover:text-foreground"
          href="https://github.com/mikhailmogilnikov"
          rel="noopener noreferrer"
          target="_blank"
          >Mikhail Mogilnikov</a
        >
      </p>
      <p class="m-0">
        <a
          class="text-foreground/55 transition-colors hover:text-foreground"
          href="/lab"
        >
          Engine lab
        </a>
        · Source code on
        <a
          class="text-foreground/55 transition-colors hover:text-foreground"
          href="https://github.com/mikhailmogilnikov/hyperellipse"
          rel="noopener noreferrer"
          target="_blank"
          >GitHub</a
        >
      </p>
    </footer>
  </main>
</Layout>
